# Venuees.in — environment variables
#
# Copy this file to `.env.local` for local dev, and paste the same values into
# Vercel (Project → Settings → Environment Variables) for production.
#
# Never commit `.env.local` — it's gitignored.

# ---- Supabase ----
# Find these in: Supabase Dashboard → your project → Settings → API
# - URL:         "Project URL"
# - ANON_KEY:    "Project API keys → anon / public"  (safe to ship to browser)
# - SERVICE_KEY: "Project API keys → service_role"   (server-only, bypasses RLS)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Optional ----
# Resend (transactional email) — add when you want enquiry-confirmation emails.
# RESEND_API_KEY=
